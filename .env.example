# ═══════════════════════════════════════════════════════════════
#  GoalFlash — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED: API-Football via RapidAPI ───────────────────────
# 1. Sign up at https://rapidapi.com (free)
# 2. Subscribe to "API-Football" → free tier = 100 req/day
# 3. Copy your RapidAPI key from the dashboard header
RAPIDAPI_KEY=your_rapidapi_key_here

# ── DEPLOYMENT: Choose ONE platform ──────────────────────────

# Option A: Cloudflare Pages (recommended for Saudi/ME latency)
# CLOUDFLARE_API_TOKEN=your_cf_api_token
# CLOUDFLARE_ACCOUNT_ID=your_cf_account_id

# Option B: Vercel
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_PROJECT_ID=your_vercel_project_id

# ── SEO & ANALYTICS ───────────────────────────────────────────
PUBLIC_GOOGLE_SITE_VERIFICATION=your_gsc_verification_code_here
PUBLIC_BING_SITE_VERIFICATION=your_bing_verification_code_here
PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
