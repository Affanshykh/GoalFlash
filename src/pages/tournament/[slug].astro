---
/**
 * tournament/[slug].astro
 * ───────────────────────
 * Root Arabic Tournament Hub Page. Features standings, matches, venues, and players.
 */

import { readdirSync, readFileSync, existsSync } from "fs";
import { resolve } from "path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MatchCard from "../../components/MatchCard.astro";
import BottomNav from "../../components/BottomNav.astro";
import tournaments from "../../data/tournaments.json";
import standings from "../../data/standings.json";

export function getStaticPaths() {
  const tournamentsPath = resolve(process.cwd(), "src/data/tournaments.json");
  if (!existsSync(tournamentsPath)) return [];
  const content = JSON.parse(readFileSync(tournamentsPath, "utf-8"));
  return content.map((t) => ({
    params: { slug: t.slug },
    props: { tournament: t },
  }));
}

const { slug } = Astro.params;
const { tournament: t } = Astro.props;

// Load all matches from JSON files to filter matches of this tournament
const matchesDir = resolve(process.cwd(), "src/data/matches");
let tournamentMatches = [];
if (existsSync(matchesDir)) {
  const files = readdirSync(matchesDir).filter((f) => f.endsWith(".json"));
  for (const file of files) {
    try {
      const content = JSON.parse(readFileSync(resolve(matchesDir, file), "utf-8"));
      // Filter matches by league name
      const filtered = content.filter((m) => m.league.name === t.leagueName);
      tournamentMatches.push(...filtered);
    } catch { /* ignore */ }
  }
}

// Group matches by Status
const liveMatches = tournamentMatches.filter(m => m.status.isLive);
const upcomingMatches = tournamentMatches.filter(m => m.status.isUpcoming);
const finishedMatches = tournamentMatches.filter(m => m.status.isFinished);

// Get league standings for this tournament
let leagueStandings = null;
if (t.slug === "saudi-pro-league") leagueStandings = standings.SPL;
else if (t.slug === "premier-league") leagueStandings = standings.EPL;

// Alternate URL for language toggle
const enAlternateURL = `${Astro.url.origin}/en/tournament/${t.slug}/`;

const title = `${t.nameAR} — ترتيب دوري وجدول مباريات وملاعب | GoalFlash`;
const description = `احصل على جدول ترتيب ${t.nameAR}، مواعيد المباريات والنتائج، الملاعب الرسمية وأسماء اللاعبين البارزين. تحديث فوري مباشر للأهداف.`;

// JSON-LD SportsLeague schema
const leagueSchema = {
  "@context": "https://schema.org",
  "@type": "SportsLeague",
  "name": t.nameAR,
  "alternateName": t.name,
  "url": Astro.url.href,
  "sport": "Soccer",
  "description": t.descriptionAR,
  "competitor": t.teams.map(team => ({
    "@type": "SportsTeam",
    "name": team.nameAR,
    "alternateName": team.name
  })),
  "hasPart": tournamentMatches.map(m => ({
    "@type": "SportsEvent",
    "name": `${m.home.nameAR} ضد ${m.away.nameAR}`,
    "alternateName": `${m.home.name} vs ${m.away.name}`,
    "startDate": m.date,
    "location": {
      "@type": "Place",
      "name": m.venue.name || "ملعب",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": m.venue.city
      }
    }
  }))
};
---

<BaseLayout title={title} description={description} lang="ar" dir="rtl" jsonLd={leagueSchema}>
  <!-- Hreflang alternate headers -->
  <link rel="alternate" hreflang="en" href={enAlternateURL} slot="head" />
  <link rel="alternate" hreflang="ar" href={Astro.url.href} slot="head" />

  <!-- Branded Header -->
  <header class="page-header" style={`border-bottom: 2px solid ${t.color}; padding-bottom: 1.5rem; margin-bottom: 2rem;`}>
    <span class="subtitle" style={`color: ${t.color}; font-family: var(--font-ar); font-weight: 800; font-size: 0.8rem; letter-spacing: 1px;`}>مركز البطولة</span>
    <h1 style="margin: 0.3rem 0; font-family: var(--font-ar); font-size: 2rem; font-weight: 900;">{t.nameAR}</h1>
    <p class="subtitle" style="margin-top:0.1rem; font-size: 1rem; color: var(--text-dim); font-weight: 400;">{t.name}</p>
    <p style="color:var(--text-muted); font-family: var(--font-ar); font-size:0.9rem; margin-top:0.75rem; max-width:800px; line-height:1.7;">{t.descriptionAR}</p>
  </header>

  <div class="portal-layout">
    <!-- Main Content (Standings & Matches) -->
    <div>
      {/* 1. STANDINGS OR TEAMS */}
      {leagueStandings ? (
        <section class="detail-section" style="margin-top: 0;">
          <h2 style="font-family: var(--font-ar); font-size: 1.2rem; font-weight: 800; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 1rem;">
            جدول الترتيب والمراكز
          </h2>
          <table class="standings-table" style="width: 100%;">
            <thead>
              <tr>
                <th>الترتيب</th>
                <th>الفريق</th>
                <th>لعب</th>
                <th>الفرق</th>
                <th style="text-align: left;">النقاط</th>
              </tr>
            </thead>
            <tbody>
              {leagueStandings.map((row) => (
                <tr>
                  <td class="standings-table__pos">{row.pos}</td>
                  <td class="standings-table__team" style="font-family: var(--font-ar); font-weight:600;">
                    {row.teamAR}
                    <span style="font-family: var(--font-body); font-size:0.75rem; color:var(--text-muted); font-weight:400; margin-right: 0.4rem;">
                      ({row.team})
                    </span>
                  </td>
                  <td>{row.played}</td>
                  <td style="direction: ltr; text-align: right;">{row.gd}</td>
                  <td class="standings-table__pts" style="text-align: left;">{row.points}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      ) : (
        <section class="detail-section" style="margin-top: 0;">
          <h2 style="font-family: var(--font-ar); font-size: 1.2rem; font-weight: 800; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 1rem;">
            المنتخبات المشاركة
          </h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.75rem;">
            {t.teams.map((team) => (
              <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 0.75rem; border-radius: 8px; text-align: center; backdrop-filter: blur(8px);">
                <div style="font-family: var(--font-ar); font-weight: 700; color: #fff; font-size: 0.85rem;">{team.nameAR}</div>
                <div style="font-size: 0.72rem; color: var(--text-muted); margin-top: 0.15rem;">{team.name}</div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* 2. MATCHES LIST */}
      <div style="margin-top: 2.5rem;">
        {/* Live Matches */}
        {liveMatches.length > 0 && (
          <section class="detail-section">
            <h2 style="color: var(--live-red); font-family: var(--font-ar); font-size: 1.2rem; font-weight: 800; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--live-red); animation: pulse 1.6s infinite;"></span>
              مباشر الآن
            </h2>
            <div class="match-list">
              {liveMatches.map((m) => <MatchCard match={m} lang="ar" />)}
            </div>
          </section>
        )}

        {/* Upcoming Matches */}
        {upcomingMatches.length > 0 && (
          <section class="detail-section">
            <h2 style="font-family: var(--font-ar); font-size: 1.2rem; font-weight: 800; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 1rem;">
              المباريات المقبلة
            </h2>
            <div class="match-list">
              {upcomingMatches.map((m) => <MatchCard match={m} lang="ar" />)}
            </div>
          </section>
        )}

        {/* Finished Matches */}
        {finishedMatches.length > 0 && (
          <section class="detail-section">
            <h2 style="font-family: var(--font-ar); font-size: 1.2rem; font-weight: 800; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 1rem;">
              نتائج المباريات المنتهية
            </h2>
            <div class="match-list">
              {finishedMatches.map((m) => <MatchCard match={m} lang="ar" />)}
            </div>
          </section>
        )}

        {tournamentMatches.length === 0 && (
          <div style="text-align:center; padding:3rem 0; color:var(--text-dim); border: 1px dashed var(--border); border-radius: 12px; font-family: var(--font-ar);">
            <p style="font-size:1.1rem; font-weight: 600;">لا توجد مباريات مسجلة في الأرشيف.</p>
            <p style="margin-top:0.4rem; font-size:0.85rem; color: var(--text-muted);">يرجى العودة لاحقاً خلال أوقات المباريات.</p>
          </div>
        )}
      </div>
    </div>

    <!-- Sidebar Widgets -->
    <aside>
      {/* Venues Widget */}
      <div class="standings-widget" style="margin-bottom: 1.5rem;">
        <h2 style="font-family: var(--font-ar);">الملاعب والاستادات الرسمية</h2>
        <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem;">
          {t.grounds.map((g) => (
            <div style="border-bottom: 1px solid var(--border); padding-bottom: 0.6rem; font-family: var(--font-ar);">
              <div style="font-weight: 700; color: #fff; font-size: 0.85rem; display: flex; justify-content: space-between;">
                <span>{g.nameAR}</span>
                <span style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-dim); font-weight: 400;">{g.name}</span>
              </div>
              <div style="font-size: 0.72rem; color: var(--text-muted); margin-top: 0.15rem; display: flex; justify-content: space-between; direction: rtl;">
                <span>📍 {g.cityAR} ({g.city})</span>
                <span>السعة: {g.capacity} متفرج</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Superstar Highlights Widget */}
      <div class="standings-widget">
        <h2 style="font-family: var(--font-ar);">أبرز النجوم واللاعبين</h2>
        <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem;">
          {t.players.map((p) => (
            <div style="border-bottom: 1px solid var(--border); padding-bottom: 0.6rem; display: flex; justify-content: space-between; align-items: center; font-family: var(--font-ar);">
              <div>
                <div style="font-weight: 700; color: #fff; font-size: 0.85rem;">{p.nameAR}</div>
                <div style="font-size: 0.72rem; color: var(--text-muted); margin-top: 0.1rem;">{p.teamAR}</div>
              </div>
              <span style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-dim);">{p.name}</span>
            </div>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <!-- Breadcrumb navigation links -->
  <div style="text-align:center; margin-top:3rem; font-size:0.85rem; font-family: var(--font-ar);">
    <a href="/">← العودة إلى الرئيسية</a>
  </div>

  <BottomNav currentPath={Astro.url.pathname} lang="ar" alternateURL={enAlternateURL} />
</BaseLayout>
