---
/**
 * ar/tournament/[slug].astro
 * ──────────────────────────
 * Redirects legacy Arabic tournament pages to root Arabic tournament pages.
 */

import { readdirSync, readFileSync, existsSync } from "fs";
import { resolve } from "path";

export function getStaticPaths() {
  const tournamentsPath = resolve(process.cwd(), "src/data/tournaments.json");
  if (!existsSync(tournamentsPath)) return [];
  const content = JSON.parse(readFileSync(tournamentsPath, "utf-8"));
  return content.map((t) => ({
    params: { slug: t.slug },
    props: { tournament: t },
  }));
}

const { tournament: t } = Astro.props;
const redirectPath = `/tournament/${t.slug}/`;
const canonicalURL = `${Astro.url.origin}${redirectPath}`;
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <link rel="canonical" href={canonicalURL} />
    <meta http-equiv="refresh" content={`0;url=${redirectPath}`} />
    <meta name="robots" content="noindex,follow" />
  </head>
  <body>
    <p>Redirecting to <a href={redirectPath}>{t.nameAR}</a>…</p>
  </body>
</html>
