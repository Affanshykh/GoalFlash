---
/**
 * en/archive/index.astro
 * ──────────────────────
 * English Match Archive Calendar. Displays multiple active match months
 * (April, May, June 2026) in a clean grid.
 */

import { readdirSync, existsSync } from "fs";
import { resolve } from "path";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BottomNav from "../../../components/BottomNav.astro";

const title = "Football Match Score Archive & Calendar | GoalFlash";
const description = "Browse past football scores, matches, and calendar archives. Look back at finished results for the World Cup and Saudi Pro League.";

const matchesDir = resolve(process.cwd(), "src/data/matches");
let archiveDates: string[] = [];

if (existsSync(matchesDir)) {
  archiveDates = readdirSync(matchesDir)
    .filter((file) => file.endsWith(".json"))
    .map((file) => file.replace(".json", ""));
}

const datesSet = new Set(archiveDates);

// Helper function to generate month grids
function generateMonthData(year: number, monthIndex: number) {
  const firstDay = new Date(year, monthIndex, 1);
  const startDayIndex = firstDay.getDay(); // 0 = Sun, 1 = Mon...
  const daysInMonth = new Date(year, monthIndex + 1, 0).getDate();
  
  const weeks: (string | null)[][] = [];
  let currentWeek: (string | null)[] = Array(7).fill(null);
  
  // Padding
  for (let i = 0; i < startDayIndex; i++) {
    currentWeek[i] = null;
  }
  
  let col = startDayIndex;
  for (let day = 1; day <= daysInMonth; day++) {
    const dayStr = String(day).padStart(2, "0");
    const monthStr = String(monthIndex + 1).padStart(2, "0");
    const dateStr = `${year}-${monthStr}-${dayStr}`;
    
    currentWeek[col] = dateStr;
    col++;
    
    if (col === 7) {
      weeks.push(currentWeek);
      currentWeek = Array(7).fill(null);
      col = 0;
    }
  }
  
  if (currentWeek.some(d => d !== null)) {
    weeks.push(currentWeek);
  }
  
  return weeks;
}

const year = 2026;
const monthsToRender = [
  { index: 3, name: "April 2026" },
  { index: 4, name: "May 2026" },
  { index: 5, name: "June 2026" }
];

const weekdayHeaders = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
const arAlternateURL = `${Astro.url.origin}/archive/`;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Scores",
      "item": `${Astro.url.origin}/en/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Score Archive",
      "item": Astro.url.href
    }
  ]
};

const collectionPageLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": Astro.url.href,
  "publisher": {
    "@type": "NewsMediaOrganization",
    "name": "GoalFlash",
    "url": Astro.url.origin
  }
};

const jsonLd = [collectionPageLd, breadcrumbLd];
---

<BaseLayout title={title} description={description} lang="en" dir="ltr" jsonLd={jsonLd}>
  <header class="page-header">
    <h1>Match Score Archive</h1>
    <p class="subtitle">Select a date to view archived match scores and results database</p>
  </header>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 1rem;">
    {monthsToRender.map((mInfo) => {
      const weeks = generateMonthData(year, mInfo.index);
      return (
        <section class="detail-section" style="margin: 0; background: rgba(255,255,255,0.01); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem;">
          <h2 class="calendar-month-title" style="margin-bottom: 1rem; font-size: 1.15rem; font-weight: 800; text-align: center; color: var(--accent);">{mInfo.name}</h2>
          
          <div class="calendar-grid">
            {weekdayHeaders.map((day) => (
              <div class="calendar-day-header" style="font-size: 0.72rem; font-weight: 700; color: var(--text-muted);">{day}</div>
            ))}
            
            {weeks.map((week) => (
              <>
                {week.map((dateStr) => {
                  if (!dateStr) return <div class="calendar-day" style="opacity: 0;" />;
                  
                  const dayNum = dateStr.split("-")[2];
                  const hasMatches = datesSet.has(dateStr);
                  
                  return hasMatches ? (
                    <a href={`/en/archive/${dateStr}/`} class="calendar-day has-matches" title={`View scores for ${dateStr}`}>
                      {parseInt(dayNum)}
                    </a>
                  ) : (
                    <div class="calendar-day">
                      {parseInt(dayNum)}
                    </div>
                  );
                })}
              </>
            ))}
          </div>
        </section>
      );
    })}
  </div>

  <BottomNav currentPath={Astro.url.pathname} lang="en" alternateURL={arAlternateURL} />
</BaseLayout>
