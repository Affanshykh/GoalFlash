---
/**
 * en/match/[slug].astro
 * ─────────────────────
 * English Match Detail Page. Features pre-rendered SEO content
 * combined with client-side real-time scoring and sharing capability.
 */

import { readdirSync, readFileSync, existsSync } from "fs";
import { resolve } from "path";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Scoreboard from "../../../components/Scoreboard.astro";
import BottomNav from "../../../components/BottomNav.astro";
import tournaments from "../../../data/tournaments.json";
import news from "../../../data/news.json";

export function getStaticPaths() {
  const matchesDir = resolve(process.cwd(), "src/data/matches");
  if (!existsSync(matchesDir)) return [];
  
  const files = readdirSync(matchesDir).filter((f) => f.endsWith(".json"));
  const allMatches = [];
  
  for (const file of files) {
    try {
      const content = JSON.parse(readFileSync(resolve(matchesDir, file), "utf-8"));
      allMatches.push(...content);
    } catch { /* ignore */ }
  }
  
  return allMatches.map((m) => ({
    params: { slug: m.slugEN },
    props: { match: m },
  }));
}

const { match: m } = Astro.props;

// ── Build SEO strings ─────────────────────────────────────────
const scoreText = m.status.isUpcoming
  ? "Preview"
  : `${m.home.goals} – ${m.away.goals}`;

const statusText = m.status.isLive
  ? "LIVE"
  : m.status.isFinished
    ? "Result"
    : "Preview";

const tournamentTag = m.isWorldCup
  ? "World Cup 2026"
  : m.badge.en;

const title = `${m.home.name} vs ${m.away.name} ${statusText} Score ${scoreText} — ${tournamentTag} | GoalFlash`;
const description = `${m.home.name} (${m.home.nameAR}) vs ${m.away.name} (${m.away.nameAR}) — ${statusText}: ${scoreText}. ${tournamentTag} match result, live goals, and score updates.`;

const arURL = `${Astro.url.origin}/match/${m.slugEN}/`;

// ── Dates ─────────────────────────────────────────────────────
const matchDate = new Date(m.date);
const dateFormatted = matchDate.toLocaleDateString("en-US", {
  weekday: "long", year: "numeric", month: "long", day: "numeric",
});
const timeRiyadh = matchDate.toLocaleTimeString("en-US", {
  hour: "2-digit", minute: "2-digit", timeZone: "Asia/Riyadh",
});
const timeLocal = matchDate.toLocaleTimeString("en-US", {
  hour: "2-digit", minute: "2-digit", timeZone: "America/New_York",
});

// Find matching tournament
const tournamentObj = tournaments.find((t) => t.leagueName === m.league.name);
const tournamentUrl = tournamentObj ? `/en/tournament/${tournamentObj.slug}/` : "/en/";

// Determine addressCountry dynamically matching the league
let addressCountry = "US";
if (!m.isWorldCup) {
  if (m.league.id === 39) addressCountry = "GB";
  else if (m.league.id === 140) addressCountry = "ES";
  else if (m.league.id === 307 || m.isSaudiLeague) addressCountry = "SA";
  else addressCountry = "SA";
}

// ── SportsEvent JSON-LD ───────────────────────────────────────
const endDate = new Date(matchDate.getTime() + 2 * 60 * 60 * 1000).toISOString();
const eventStatus = m.status.isFinished
  ? "https://schema.org/EventCompleted"
  : m.status.isLive
    ? "https://schema.org/EventActive"
    : "https://schema.org/EventScheduled";

const sportsEventLd = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  name: `${m.home.name} vs ${m.away.name}`,
  description: `${tournamentTag} football match between ${m.home.name} and ${m.away.name}`,
  startDate: m.date,
  endDate: endDate,
  eventStatus: eventStatus,
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: m.venue.name || "Stadium",
    address: {
      "@type": "PostalAddress",
      addressLocality: m.venue.city,
      addressCountry: addressCountry,
    },
  },
  homeTeam: {
    "@type": "SportsTeam",
    name: m.home.name,
    alternateName: m.home.nameAR,
    ...(m.home.logo ? { logo: m.home.logo } : {}),
  },
  awayTeam: {
    "@type": "SportsTeam",
    name: m.away.name,
    alternateName: m.away.nameAR,
    ...(m.away.logo ? { logo: m.away.logo } : {}),
  },
  ...((m.status.isFinished || m.status.isLive) && {
    result: {
      "@type": "SportsEventResult",
      homeScore: m.home.goals,
      awayScore: m.away.goals,
    },
  }),
  organizer: {
    "@type": "SportsOrganization",
    name: m.isWorldCup ? "FIFA" : m.league.name,
  },
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Scores", item: `${Astro.url.origin}/en/` },
    { "@type": "ListItem", position: 2, name: tournamentTag },
    { "@type": "ListItem", position: 3, name: `${m.home.name} vs ${m.away.name}` },
  ],
};

const matchingArticle = news.find((item) => item.linkEN === `/match/${m.slugEN}/`);
let newsArticleLd = null;
if (matchingArticle) {
  newsArticleLd = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: matchingArticle.title,
    description: matchingArticle.summary,
    datePublished: matchingArticle.date,
    dateModified: matchingArticle.date,
    mainEntityOfPage: Astro.url.href,
    image: [`${Astro.url.origin}/og-default.png`],
    author: {
      "@type": "Organization",
      name: "GoalFlash Editorial",
      url: Astro.url.origin,
    },
    publisher: {
      "@type": "NewsMediaOrganization",
      name: "GoalFlash",
      url: Astro.url.origin,
      logo: {
        "@type": "ImageObject",
        url: `${Astro.url.origin}/og-default.png`,
      },
    },
    about: {
      "@type": "SportsEvent",
      name: `${m.home.name} vs ${m.away.name}`,
      startDate: m.date,
      location: {
        "@type": "Place",
        name: m.venue.name || "Stadium",
      },
    },
  };
}

const jsonLd = [sportsEventLd, breadcrumbLd];
if (newsArticleLd) {
  jsonLd.push(newsArticleLd);
}
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  dir="ltr"
  jsonLd={jsonLd}
>
  <link rel="alternate" hreflang="ar" href={arURL} slot="head" />
  <link rel="alternate" hreflang="en" href={Astro.url.href} slot="head" />

  <article class="match-detail">
    <!-- Header -->
    <header class="page-header">
      <p class="subtitle">
        <a href={tournamentUrl} style={`color: ${m.badge.color}; text-decoration: none; font-weight: 700;`}>
          {tournamentTag}
        </a>
      </p>
      <h1>{m.home.name} vs {m.away.name}</h1>
      <p class="subtitle" style="direction:rtl;margin-top:0.2rem;font-family:var(--font-ar);">
        {m.home.nameAR} ضد {m.away.nameAR}
      </p>
      <p style="color:var(--text-muted);font-size:0.78rem;margin-top:0.5rem;">
        {dateFormatted} &middot; {timeRiyadh} Riyadh
        {m.isWorldCup && <> &middot; {timeLocal} ET</>}
        {m.venue.name && <> &middot; {m.venue.name}, {m.venue.city}</>}
      </p>
    </header>

    <!-- GIANT SCORE -->
    <Scoreboard match={m} lang="en" />

    <!-- Sharing Section -->
    <section class="share-section">
      <span>Share Match</span>
      <div class="share-buttons">
        <button class="share-btn share-btn--x" id="share-x" data-text={title}>
          𝕏 Post
        </button>
        <button class="share-btn share-btn--wa" id="share-wa" data-text={title}>
          WhatsApp
        </button>
        <button class="share-btn share-btn--link" id="share-link" data-copied-text="Copied!">
          Copy Link
        </button>
      </div>
    </section>

    <!-- Score breakdown table -->
    {m.status.isFinished && (
      <section class="detail-section">
        <h2>Score Breakdown</h2>
        <table class="score-table">
          <thead>
            <tr>
              <th></th>
              <th>{m.home.name}</th>
              <th>{m.away.name}</th>
            </tr>
          </thead>
          <tbody>
            {m.score.halftime.home !== null && (
              <tr>
                <td>Half Time</td>
                <td>{m.score.halftime.home}</td>
                <td>{m.score.halftime.away}</td>
              </tr>
            )}
            <tr>
              <td>Full Time</td>
              <td>{m.score.fulltime.home ?? "–"}</td>
              <td>{m.score.fulltime.away ?? "–"}</td>
            </tr>
            {m.score.extratime.home !== null && (
              <tr>
                <td>Extra Time</td>
                <td>{m.score.extratime.home}</td>
                <td>{m.score.extratime.away}</td>
              </tr>
            )}
            {m.score.penalty.home !== null && (
              <tr>
                <td>Penalties</td>
                <td>{m.score.penalty.home}</td>
                <td>{m.score.penalty.away}</td>
              </tr>
            )}
          </tbody>
        </table>
      </section>
    )}

    <!-- Match info content block -->
    <section class="detail-section">
      <h2>Match Info</h2>
      <p id="match-info-para">
        <strong>{m.home.name}</strong> ({m.home.nameAR})
        {m.status.isFinished ? "played" : "plays"} against
        <strong>{m.away.name}</strong> ({m.away.nameAR})
        in a <strong>{tournamentTag}</strong> fixture
        {m.league.round && <> ({m.league.round})</>}
        {m.venue.name && <> at {m.venue.name} in {m.venue.city}</>}
        on {dateFormatted}.
        {m.status.isFinished &&
          ` The final score was ${m.home.goals}–${m.away.goals}.`}
        {m.status.isLive &&
          ` The match is currently live at ${m.home.goals}–${m.away.goals} (${m.status.elapsed}').`}
        {m.status.isUpcoming &&
          ` Kickoff is scheduled for ${timeRiyadh} (Riyadh time).`}
      </p>
    </section>

    <!-- SEO long-tail content -->
    <section class="detail-section">
      <h2>About</h2>
      <p>
        This page shows the latest score and match result for
        {m.home.name} vs {m.away.name} in the
        {m.isWorldCup ? "2026 FIFA World Cup" : m.league.name}
        ({m.league.nameAR}).
        {m.isWorldCup
          ? " The 2026 World Cup is hosted across the United States, Mexico, and Canada — the first tournament with 48 teams."
          : ` The ${m.league.name} features top clubs competing in Saudi Arabia's premier football division.`}
        {" "}Scores are updated multiple times daily during match days.
      </p>
    </section>

    <!-- Interlinking Links -->
    <div style="text-align:center;margin-top:2rem;display:flex;gap:1.5rem;justify-content:center;font-size:0.85rem;">
      <a href="/en/">← All Scores</a>
      <a href="/en/archive/">Archive Calendar 📅</a>
      <a href={arURL} style="font-family:var(--font-ar);">العربية →</a>
    </div>
  </article>

  <BottomNav currentPath={Astro.url.pathname} lang="en" alternateURL={arURL} />

  <!-- Client-Side Real-Time Score Engine & Sharing Script -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      // 1. Live Scores Polling Logic
      const container = document.getElementById("scoreboard-container");
      if (!container) return;

      const matchId = container.getAttribute("data-match-id");
      let matchStatus = container.getAttribute("data-match-status");

      // Check if match status is live
      const liveStatuses = ["1H", "2H", "HT", "ET", "P", "BT", "INT"];
      
      if (liveStatuses.includes(matchStatus)) {
        const homeGoalsVal = document.getElementById("home-goals-val");
        const awayGoalsVal = document.getElementById("away-goals-val");
        const statusLabel = document.getElementById("status-label");
        const breakdownContainer = document.getElementById("breakdown-container");
        const matchInfoPara = document.getElementById("match-info-para");

        const pollInterval = setInterval(async () => {
          try {
            const res = await fetch(`/api/live-score/${matchId}`);
            if (!res.ok) throw new Error("Network response error");
            const data = await res.json();

            // Animate on goal updates
            if (data.home.goals !== null && homeGoalsVal.textContent !== String(data.home.goals)) {
              homeGoalsVal.textContent = data.home.goals;
              homeGoalsVal.classList.add("goal-pulse");
              setTimeout(() => homeGoalsVal.classList.remove("goal-pulse"), 4500);
            }
            if (data.away.goals !== null && awayGoalsVal.textContent !== String(data.away.goals)) {
              awayGoalsVal.textContent = data.away.goals;
              awayGoalsVal.classList.add("goal-pulse");
              setTimeout(() => awayGoalsVal.classList.remove("goal-pulse"), 4500);
            }

            // Update status
            const elapsed = data.status.elapsed ? ` ${data.status.elapsed}'` : "";
            if (data.status.isLive) {
              statusLabel.textContent = `LIVE${elapsed}`;
              statusLabel.className = "scoreboard__status status--live";
              if (matchInfoPara) {
                matchInfoPara.innerHTML = matchInfoPara.innerHTML.replace(
                  /currently live at \d+–\d+ \(\d+'\)/,
                  `currently live at ${data.home.goals}–${data.away.goals} (${data.status.elapsed}')`
                );
              }
            } else if (data.status.isFinished) {
              statusLabel.textContent = "Full Time";
              statusLabel.className = "scoreboard__status status--ft";
              
              // Show score breakdown
              if (breakdownContainer && data.score) {
                breakdownContainer.style.display = "flex";
                breakdownContainer.innerHTML = "";
                if (data.score.halftime.home !== null) {
                  breakdownContainer.innerHTML += `<span>HT: ${data.score.halftime.home}–${data.score.halftime.away}</span>`;
                }
                if (data.score.extratime.home !== null) {
                  breakdownContainer.innerHTML += `<span>ET: ${data.score.extratime.home}–${data.score.extratime.away}</span>`;
                }
                if (data.score.penalty.home !== null) {
                  breakdownContainer.innerHTML += `<span>PEN: ${data.score.penalty.home}–${data.score.penalty.away}</span>`;
                }
              }
              clearInterval(pollInterval);
            }
          } catch (error) {
            console.warn("Live score refresh failed:", error);
          }
        }, 30000); // 30s
      }

      // 2. Share Buttons Logic
      const shareX = document.getElementById("share-x");
      const shareWA = document.getElementById("share-wa");
      const shareLink = document.getElementById("share-link");
      const currentUrl = window.location.href;

      if (shareX) {
        shareX.addEventListener("click", () => {
          const text = encodeURIComponent(shareX.getAttribute("data-text") || "");
          const url = `https://twitter.com/intent/tweet?text=${text}&url=${encodeURIComponent(currentUrl)}`;
          window.open(url, "_blank");
        });
      }

      if (shareWA) {
        shareWA.addEventListener("click", () => {
          const text = encodeURIComponent(shareWA.getAttribute("data-text") || "");
          const url = `https://api.whatsapp.com/send?text=${text}%20${encodeURIComponent(currentUrl)}`;
          window.open(url, "_blank");
        });
      }

      if (shareLink) {
        shareLink.addEventListener("click", async () => {
          if (navigator.share) {
            try {
              await navigator.share({
                title: document.title,
                url: currentUrl,
              });
              return;
            } catch (err) {
              console.log("Web Share cancelled/failed", err);
            }
          }

          try {
            await navigator.clipboard.writeText(currentUrl);
            const originalText = shareLink.innerHTML;
            shareLink.textContent = shareLink.getAttribute("data-copied-text") || "Copied!";
            shareLink.style.background = "var(--accent)";
            shareLink.style.color = "var(--bg)";
            shareLink.style.borderColor = "var(--accent)";
            setTimeout(() => {
              shareLink.innerHTML = originalText;
              shareLink.style.background = "";
              shareLink.style.color = "";
              shareLink.style.borderColor = "";
            }, 2000);
          } catch (err) {
            console.error("Link copy failed", err);
          }
        });
      }
    });
  </script>
</BaseLayout>
